generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
}

model Firm {
  id                        String        @id @default(cuid())
  name                      String
  slug                      String        @unique
  logoUrl                   String?
  primaryColor              String?       @default("#ffffff")
  physicalAddress           String?
  linkedInUrl               String?
  googleReviewsUrl          String?
  bio                       String?
  heroMediaUrl              String?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  accentColor               String?       @default("#151515")
  backgroundColor           String?       @default("#0a0a0a")
  fontColor                 String?       @default("#ffffff")
  showAgencyBranding        Boolean       @default(true)
  logoScale                 Float         @default(100.0)
  borderRadius              String        @default("rounded")
  bioFontFamily             String        @default("Inter")
  bioFontSize               Int           @default(18)
  firmNameFontFamily        String        @default("Inter")
  firmNameFontSize          Int           @default(72)
  firmNameFontWeight        String        @default("900")
  isColorLinked             Boolean       @default(false)
  isFontLinked              Boolean       @default(false)
  bioFontColor              String        @default("#000000")
  firmNameFontColor         String        @default("#000000")
  memberCardBgColor         String        @default("rgba(255, 255, 255, 0.5)")
  memberPhotoSpacing        Int           @default(12)
  showMemberNarrative       Boolean       @default(true)
  isMemberCardColorLinked   Boolean       @default(false)
  cardShadowIntensity       Float         @default(0.0)
  portfolioListStyle        String        @default("TRADITIONAL")
  showSearchBar             Boolean       @default(true)
  teamListStyle             String        @default("TRADITIONAL")
  viewLayoutMode            String        @default("BOTH")
  tombstoneInfoBgColor      String?       @default("#ffffff")
  tombstoneLayout           String[]      @default(["INFO", "METRICS", "MEDIA", "NARRATIVE"])
  tombstoneMaxWidth         Int           @default(1200)
  tombstoneMediaBgColor     String?       @default("#ffffff")
  tombstoneMetricsBgColor   String?       @default("#f8f9fa")
  tombstoneNarrativeBgColor String?       @default("#ffffff")
  tombstonePadding          Int           @default(48)
  activityLogs              ActivityLog[]
  deals                     Deal[]
  invitations               Invitation[]
  teamMembers               TeamMember[]
  users                     User[]
  tasks                     Task[]
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  role      UserRole @default(USER)
  firmId    String
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
  firm      Firm     @relation(fields: [firmId], references: [id])
}

model User {
  id                  String      @id @default(cuid())
  email               String      @unique
  password            String
  role                UserRole    @default(USER)
  firmId              String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  name                String?
  resetToken          String?     @unique
  resetTokenExpires   DateTime?
  professionalProfile TeamMember?
  firm                Firm        @relation(fields: [firmId], references: [id])
}

model TeamMember {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  role         String
  email        String?          @unique
  imageURL     String?
  firmId       String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  bio          String?
  firmIds      String[]         @default([])
  heroMediaUrl String?
  linkedInUrl  String?
  phoneNumber  String?
  sortOrder    Int              @default(0)
  userId       String?          @unique
  department   String?
  managerId    String?
  manager      TeamMember?      @relation("Management", fields: [managerId], references: [id])
  reports      TeamMember[]     @relation("Management")
  deals        Deal[]
  tasks        Task[]
  firm         Firm             @relation(fields: [firmId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])
  files        AssetFile[]
}

model AssetFile {
  id           String     @id @default(cuid())
  name         String
  content      String
  type         String     @default("OTHER")
  teamMemberId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@index([teamMemberId])
  @@map("TeamMemberFile")
}

model Deal {
  id                 String      @id @default(cuid())
  address            String
  assetType          AssetType
  strategy           Strategy
  purchaseAmount     Float?
  financedAmount     Float?
  stillImageURL      String?
  generatedVideoURL  String?
  isPublic           Boolean     @default(false)
  capRate            Float?
  sqFt               Float?
  firmId             String
  teamMemberId       String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  arv                Float?
  context            String?
  financingType      String?
  images             String[]    @default([])
  investmentOverview String?
  rehabAmount        Float?
  teamMemberIds      String[]    @default([])
  sortOrder          Int         @default(0)
  firm               Firm        @relation(fields: [firmId], references: [id])
  teamMember         TeamMember? @relation(fields: [teamMemberId], references: [id])
}

model ActivityLog {
  id               String   @id @default(cuid())
  type             String
  title            String
  timestamp        DateTime @default(now())
  firmId           String?
  dealId           String?
  userId           String?
  memberId         String?
  performedByEmail String?
  firm             Firm?    @relation(fields: [firmId], references: [id])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("INBOX")
  priority    String   @default("NORMAL")
  assigneeId  String?
  dueDate     DateTime?
  firmId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  firm        Firm     @relation(fields: [firmId], references: [id])
  assignee    TeamMember? @relation(fields: [assigneeId], references: [id])
}

enum UserRole {
  FIRM_ADMIN
  USER
  SYSTEM_ADMIN
}

enum AssetType {
  INDUSTRIAL
  RETAIL
  MULTIFAMILY
  SF
  OFFICE
  HOTEL
  HOSPITALITY
  MIXED_USE
  LAND
}

enum Strategy {
  BUY_AND_HOLD
  FIX_FLIP
  VALUE_ADD
  CORE
  STABILIZED
  OPPORTUNISTIC
}
