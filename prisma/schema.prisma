generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Firm {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  logoUrl            String?
  primaryColor       String?      @default("#ffffff")
  physicalAddress    String?
  linkedInUrl        String?
  googleReviewsUrl   String?
  bio                String?
  heroMediaUrl       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  accentColor        String?      @default("#151515")
  backgroundColor    String?      @default("#0a0a0a")
  fontColor          String?      @default("#ffffff")
  showAgencyBranding Boolean      @default(true)
  logoScale          Float        @default(100.0)
  borderRadius       String       @default("rounded")
  isColorLinked      Boolean      @default(false)
  firmNameFontFamily String       @default("Inter")
  firmNameFontWeight String       @default("900")
  firmNameFontSize   Int          @default(72)
  bioFontFamily      String       @default("Inter")
  bioFontSize        Int          @default(18)
  deals              Deal[]
  teamMembers        TeamMember[]
  users              User[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  firmId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  firm      Firm     @relation(fields: [firmId], references: [id])
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  role      String
  email     String?  @unique
  imageURL  String?
  firmId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]
  firm      Firm     @relation(fields: [firmId], references: [id])
}

model Deal {
  id                String      @id @default(cuid())
  address           String
  assetType         AssetType
  strategy          Strategy
  purchaseAmount    Float?
  financedAmount    Float?
  stillImageURL     String?
  generatedVideoURL String?
  isPublic          Boolean     @default(false)
  capRate           Float?
  sqFt              Float?
  firmId            String
  teamMemberId      String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  firm              Firm        @relation(fields: [firmId], references: [id])
  teamMember        TeamMember? @relation(fields: [teamMemberId], references: [id])
}

enum UserRole {
  FIRM_ADMIN
  USER
  SYSTEM_ADMIN
}

enum AssetType {
  INDUSTRIAL
  RETAIL
  MULTIFAMILY
  SF
}

enum Strategy {
  BUY_AND_HOLD
  FIX_FLIP
}
